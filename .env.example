# Estas variáveis são configuradas automaticamente pelo Railway
# NÃO é necessário alterar nada aqui

# Injetado automaticamente ao adicionar o PostgreSQL no Railway:
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Injetado automaticamente pelo Railway:
PORT=3000
NODE_ENV=production

# Opcional - para usar a IA do Gemini:
# GEMINI_API_KEY=sua_chave_aqui
